# GitHub Personal Access Token (public_repo or repo scope)
# Required for the `publish` command to open PRs on GiottoVerducci/TWD
GITHUB_TOKEN=ghp_your_token_here

# vekn.net account credentials. Required by `scrape`, `validate`, and `tda-scrape` to
# log into the player registry — anonymous requests get a bare login form instead of
# player data, so without these every registry lookup fails.
VEKN_USERNAME=your_vekn_username
VEKN_PASSWORD=your_vekn_password

# Minimum number of players for a tournament to be considered valid (default: 10)
MIN_PLAYERS=10
